# =============================================================================
# Saki Operations — Environment Variables
# Copy this file to .env and fill in values. Never commit real secrets.
# =============================================================================

# --- Application ---
NODE_ENV=development
# Optional: development | staging | production (defaults from NODE_ENV / Vite mode)
# APP_ENV=development
# VITE_APP_ENV=development
APP_NAME=Saki Operations
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
API_PREFIX=api/v1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://saki:saki@localhost:5432/saki_operations?schema=public
POSTGRES_USER=saki
POSTGRES_PASSWORD=saki
POSTGRES_DB=saki_operations
POSTGRES_PORT=5432

# --- Authentication (JWT) ---
# Production: API WILL NOT START unless JWT_SECRET is set, is not a placeholder,
# and is at least 32 characters (Phase 9.1 / C-01).
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Development seeding (never enable in production) ---
# ALLOW_DEV_SEED=true
# DEV_SEED_PASSWORD=SakiOps@2026Secure

# --- Production admin bootstrap (pnpm create-admin) ---
# ADMIN_PASSWORD=use-a-long-random-password

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=saki-operations
R2_PUBLIC_URL=
R2_ENDPOINT=

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Web (Vite) ---
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Saki Operations
VITE_APP_TAGLINE=Powered by Saki Tours & Weddings
