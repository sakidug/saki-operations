{
  "name": "@saki-operations/web",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @saki-operations/types build && pnpm --filter @saki-operations/constants build && tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "start": "serve dist -s -n -l tcp://0.0.0.0:${PORT:-4173}",
    "start:prod": "pnpm run start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist .turbo dev-dist"
  },
  "dependencies": {
    "@saki-operations/constants": "workspace:^",
    "@saki-operations/forms": "workspace:*",
    "@saki-operations/i18n": "workspace:*",
    "@saki-operations/ocr": "workspace:*",
    "@saki-operations/operations-session": "workspace:*",
    "@saki-operations/types": "workspace:*",
    "@saki-operations/ui": "workspace:*",
    "framer-motion": "^12.5.0",
    "i18next": "^26.3.6",
    "lucide-react": "^0.483.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@saki-operations/eslint-config": "workspace:*",
    "@saki-operations/typescript-config": "workspace:*",
    "@tailwindcss/vite": "^4.0.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
