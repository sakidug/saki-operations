{
  "name": "@saki-operations/api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "node ../../scripts/generate-build-meta.mjs && nest start --watch",
    "build": "node ../../scripts/generate-build-meta.mjs && pnpm --filter @saki-operations/build-info build && nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "pnpm --filter=@saki-operations/database db:generate",
    "db:migrate": "pnpm --filter=@saki-operations/database db:migrate",
    "db:migrate:deploy": "pnpm --filter=@saki-operations/database db:migrate:deploy",
    "db:seed": "pnpm --filter=@saki-operations/database db:seed",
    "db:studio": "pnpm --filter=@saki-operations/database db:studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@prisma/client": "^6.5.0",
    "@saki-operations/build-info": "workspace:^",
    "@saki-operations/constants": "workspace:^",
    "@saki-operations/database": "workspace:*",
    "@saki-operations/types": "workspace:*",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@saki-operations/eslint-config": "workspace:*",
    "@saki-operations/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2"
  }
}
