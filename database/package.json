{
  "name": "@saki-operations/database",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:generate": "prisma generate --schema=./schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./schema/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./schema/schema.prisma",
    "db:seed": "prisma db seed --schema=./schema/schema.prisma",
    "db:studio": "prisma studio --schema=./schema/schema.prisma",
    "clean": "rm -rf .turbo"
  },
  "prisma": {
    "schema": "schema/schema.prisma",
    "seed": "tsx seeds/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
